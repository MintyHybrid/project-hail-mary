{
  "@context": "https://doi.org/10.5063/schema/codemeta-2.0",
  "@type": "SoftwareSourceCode",
  "identifier": "potytools",
  "description": "Provides functions for potyvirus genomic analysis, including GenBank file parsing (no external dependencies), codon usage bias calculation (RSCU, ENC, CAI, GC content), host classification for monocot/dicot-infecting isolates, motif-flanking region extraction and concatenation for short-linear-motif analysis, and phylogenetic utilities. Designed for reproducible analysis of Potyviridae diversity, DNAzyme-like motif conservation, and horizontal gene transfer detection.",
  "name": "potytools: Analysis Tools for Potyvirus Genomics and Short Linear Motifs",
